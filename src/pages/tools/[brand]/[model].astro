---
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import Base from '../../../layouts/Base.astro';
import { slugify, faultUrl } from '../../../lib/slug';

export async function getStaticPaths() {
  const entries = await getCollection('faults');
  return entries.map((entry) => ({
    params: {
      brand: slugify(entry.data.brand),
      model: slugify(entry.data.model),
    },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const {
  brand,
  model,
  category,
  symptom,
  likely_cause,
  diagnostic_steps,
  fix_or_verdict,
  sources,
  date_published,
  image,
  image_alt,
} = entry.data;

const dateLabel = date_published.toLocaleDateString('en-GB', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});

const pageUrl = faultUrl(entry);

const comments = (await getCollection('comments'))
  .filter((c) => c.data.entry === entry.id)
  .sort((a, b) => a.data.date.valueOf() - b.data.date.valueOf());
const renderedComments = await Promise.all(
  comments.map(async (c) => ({ data: c.data, Content: (await render(c)).Content }))
);
---

<Base title={`${brand} ${model} — ${symptom}`} description={`${brand} ${model}: ${symptom}. Likely cause: ${likely_cause}`}>
  <article class="wrap" data-pagefind-body>
    <nav class="crumbs" aria-label="Breadcrumb" data-pagefind-ignore>
      <a href="/">Home</a><span class="sep">/</span>
      <a href="/faults/">Faults</a><span class="sep">/</span>
      <span>{brand} {model}</span>
    </nav>

    <header class="article-head">
      <p class="kicker" data-pagefind-meta="title">{brand} {model}</p>
      <h1>{symptom}</h1>
    </header>

    {image && (
      <figure class="entry-hero" data-pagefind-ignore>
        <Image src={image} alt={image_alt ?? `${brand} ${model} — ${symptom}`} width={1200} />
      </figure>
    )}

    <div class="plate">
      <div class="plate-head">
        <span class="plate-title">Quick Facts</span>
      </div>
      <dl>
        <dt>Brand</dt>
        <dd>{brand}</dd>
        <dt>Model</dt>
        <dd><code>{model}</code></dd>
        <dt>Category</dt>
        <dd><span class="tag tag-category" data-pagefind-filter="category">{category}</span></dd>
        <dt>Symptom</dt>
        <dd>{symptom}</dd>
        <dt>Likely cause</dt>
        <dd>{likely_cause}</dd>
        <dt>Diagnostic steps</dt>
        <dd>
          <ol>
            {diagnostic_steps.map((step) => <li>{step}</li>)}
          </ol>
        </dd>
        <dt>Fix / verdict</dt>
        <dd><strong>{fix_or_verdict}</strong></dd>
        {sources && sources.length > 0 && (
          <>
            <dt>Sources</dt>
            <dd>
              <ul class="sources">
                {sources.map((src) => <li>{src}</li>)}
              </ul>
            </dd>
          </>
        )}
        <dt>Published</dt>
        <dd>{dateLabel}</dd>
      </dl>
    </div>

    <div class="safety-notice" data-pagefind-ignore>
      <strong>⚠ Work safe, at your own risk.</strong> Unplug before opening anything;
      capacitors can hold charge after power-off. This is general information, not
      professional advice — if you're not competent with mains-powered equipment, use a
      qualified technician. Full <a href="/terms/">terms &amp; liability disclaimer</a>.
    </div>

    <div class="article-body">
      <Content />
    </div>

    <section class="comments" id="comments" data-pagefind-ignore>
      <div class="section-head">
        <h2>Comments &amp; Corrections</h2>
      </div>

      {renderedComments.length === 0 ? (
        <p class="no-comments">
          No comments yet. Had this fault yourself, or found something different? Tell us below.
        </p>
      ) : (
        <ol class="comment-list">
          {renderedComments.map(({ data, Content: CommentBody }) => (
            <li class="comment">
              <div class="comment-meta">
                <span class="comment-author">{data.author}</span>
                <span>{data.date.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' })}</span>
              </div>
              <div class="comment-body">
                <CommentBody />
              </div>
            </li>
          ))}
        </ol>
      )}

      <p id="comment-thanks" class="comment-thanks" hidden>
        Thanks — your comment has been sent for review. Comments are checked by a human
        before they appear, so expect a delay.
      </p>

      <form
        class="form-panel comment-form"
        name="entry-comments"
        method="POST"
        action={`${pageUrl}?comment=received#comments`}
        data-netlify="true"
        netlify-honeypot="website"
      >
        <input type="hidden" name="form-name" value="entry-comments" />
        <input type="hidden" name="entry" value={entry.id} />
        <p style="display: none;">
          <label>Leave this field empty: <input name="website" /></label>
        </p>

        <div class="form-field">
          <label for="comment-name">Name</label>
          <input type="text" id="comment-name" name="name" required maxlength="80" />
        </div>
        <div class="form-field">
          <label for="comment-email">Email (never published — only if we need to reply)</label>
          <input type="email" id="comment-email" name="email" />
        </div>
        <div class="form-field">
          <label for="comment-text">Comment</label>
          <textarea id="comment-text" name="comment" rows="5" required maxlength="4000"></textarea>
        </div>
        <button class="btn" type="submit">Submit comment</button>
        <p class="comment-note">
          Comments are reviewed before publishing — nothing appears automatically, and spam
          never appears at all.
        </p>
      </form>
    </section>
  </article>
</Base>

<script>
  if (new URLSearchParams(window.location.search).get('comment') === 'received') {
    document.getElementById('comment-thanks')?.removeAttribute('hidden');
    document.querySelector('.comment-form')?.setAttribute('hidden', '');
  }
</script>
